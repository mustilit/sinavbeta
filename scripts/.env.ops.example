# ============================================================================
# .env.ops.example
# ============================================================================
# Bu dosyayı `.env.ops` olarak kopyalayın ve gerçek değerlerle doldurun.
# .env.ops .gitignore'da — repo'ya commit edilmez.
#
# Kullanım: sync-prod-to-staging.sh otomatik olarak bu dosyayı yükler.
# ============================================================================

# ── PROD SUNUCUSU ─────────────────────────────────────────────────────────────
# SSH erişim bilgileri (read-only DB user kullanılması TAVSİYE EDİLİR)
PROD_SSH_USER=deploy
PROD_SSH_HOST=prod.sinavsalonu.com           # veya doğrudan IP
PROD_SSH_KEY=/home/youruser/.ssh/sinav_ops_key

# Prod PostgreSQL erişimi (sadece dump için kullanılır)
# ÖNERİ: Sadece SELECT yetkisi olan ayrı bir user oluştur:
#   CREATE USER sinav_dump WITH PASSWORD 'xxx';
#   GRANT CONNECT ON DATABASE sinavsalonu TO sinav_dump;
#   GRANT USAGE ON SCHEMA public TO sinav_dump;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO sinav_dump;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO sinav_dump;
PROD_DB_NAME=sinavsalonu
PROD_DB_USER=sinav_dump
PROD_DB_PASS=<read-only-password>

# ── STAGING SUNUCUSU ──────────────────────────────────────────────────────────
STAGING_SSH_USER=deploy
STAGING_SSH_HOST=staging.sinavsalonu.com     # veya doğrudan IP
STAGING_SSH_KEY=/home/youruser/.ssh/sinav_ops_key

# Staging PostgreSQL (sınırsız yetki — staging'i recreate edebilmek için)
STAGING_DB_NAME=sinavsalonu_staging
STAGING_DB_USER=postgres
STAGING_DB_PASS=<staging-postgres-superuser-password>

# Staging Redis (FLUSHALL için)
STAGING_REDIS_HOST=localhost
STAGING_REDIS_PORT=6379

# ── OPSIYONEL: Bildirim ───────────────────────────────────────────────────────
# Senkronizasyon tamamlandığında bildirim göndermek isterseniz:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
